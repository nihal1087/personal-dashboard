{
  "manifest_version": 3,
  "name": "Personal Dashboard",
  "version": "1.0.0",
  "description": "A customizable new tab dashboard with live time, weather, GitHub repositories, LeetCode progress, quotes, and dynamic backgrounds.",

  "chrome_url_overrides": {
    "newtab": "index.html"
  },

  "permissions": [
    "geolocation"
  ],

  "host_permissions": [
    "https://apis.scrimba.com/*",
    "https://api.github.com/*",
    "https://alfa-leetcode-api.onrender.com/*",
    "https://zenquotes.io/*",
    "https://openweathermap.org/*"
  ],

  "icons": {
    "16": "icons/icon16.png"
  }
}
